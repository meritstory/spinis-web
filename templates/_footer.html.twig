<footer class="border-t border-border-default bg-white py-10">
    <div class="mx-auto mb-8 flex max-w-[1200px] items-center justify-between border-b border-border-default px-6 pb-8">
        <a href="{{ path('home') }}" class="text-body-md text-text-primary">
            <span class="text-primary font-bold">{{ 'layout.logo.accent'|trans }}</span> {{ 'layout.logo.rest'|trans }}
        </a>

        <div class="flex gap-3">
            <a href="#" aria-label="{{ 'footer.social.facebook'|trans }}" class="flex h-8 w-8 items-center justify-center rounded-full border border-border-default bg-white">
                <img src="{{ asset('images/facebook.svg') }}" class="h-4 w-4 object-contain" alt="">
            </a>
            <a href="#" aria-label="{{ 'footer.social.twitter'|trans }}" class="flex h-8 w-8 items-center justify-center rounded-full border border-border-default bg-white">
                <img src="{{ asset('images/twitter.svg') }}" class="h-4 w-4 object-contain" alt="">
            </a>
            <a href="#" aria-label="{{ 'footer.social.linkedin'|trans }}" class="flex h-8 w-8 items-center justify-center rounded-full border border-border-default bg-white">
                <img src="{{ asset('images/linkedin.svg') }}" class="h-4 w-4 object-contain" alt="">
            </a>
        </div>
    </div>

    <div class="mx-auto grid max-w-[1200px] grid-cols-4 gap-6 px-6">
        {# TODO: org code/address/email/phone are still hardcoded -- likely becomes an admin-managed settings entity later, same as the social links #}
        <div>
            <h3 class="mb-1 text-body-md font-bold leading-none">{{ 'footer.org_code.label'|trans }}</h3>
            <p class="text-body-md text-text-primary">191352247</p>
        </div>
        <div>
            <h3 class="mb-1 text-body-md font-bold leading-none">{{ 'footer.address.label'|trans }}</h3>
            <p class="text-body-md text-text-primary">A. Juozapavičiaus g. 9, LT-09311<br>Vilnius</p>
        </div>
        <div>
            <h3 class="mb-1 text-body-md font-bold leading-none">{{ 'footer.email.label'|trans }}</h3>
            <p class="text-body-md text-text-primary">vaspvt@vaspvt.gov.lt</p>
        </div>
        <div>
            <h3 class="mb-1 text-body-md font-bold leading-none">{{ 'footer.phone.label'|trans }}</h3>
            <p class="text-body-md text-text-primary">+370 5 261 5177</p>
        </div>
    </div>
</footer>
