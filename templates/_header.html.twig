<header class="border-b border-border-default">
    <div class="mx-auto flex max-w-[1200px] items-center justify-between gap-6 px-6 py-5">
        <a href="{{ path('home') }}" class="whitespace-nowrap text-body-md text-text-primary">
            <span class="text-primary font-bold">{{ 'layout.logo.accent'|trans }}</span> {{ 'layout.logo.rest'|trans }}
        </a>

        <nav class="ml-auto flex items-center gap-6 text-body-lg text-text-secondary">
            <a href="#">{{ 'nav.about'|trans }}</a>
            <a href="{{ path('duk') }}">{{ 'nav.faq'|trans }}</a>
            <a href="#">{{ 'nav.privacy'|trans }}</a>
            <a href="#">{{ 'nav.contacts'|trans }}</a>
        </nav>

        <div class="relative" data-controller="dropdown">
            <button
                type="button"
                class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-border-default text-primary"
                data-action="dropdown#toggle click@window->dropdown#closeOnClickOutside"
                data-dropdown-target="toggle"
                aria-haspopup="true"
                aria-expanded="false"
                aria-label="{{ 'header.user_menu_label'|trans }}"
            >
                <img src="{{ asset('images/user.svg') }}" width="24" height="24" alt="">
            </button>

            <div class="absolute right-0 top-[calc(100%+8px)] z-10 min-w-[308px] rounded-sm border border-border-default bg-white shadow-[0_2px_20px_rgba(99,115,129,0.10)]" data-dropdown-target="panel" hidden>
                {% if app.user %}
                    <a href="#" class="flex items-center gap-2 rounded-sm px-3 py-2 text-body-lg text-text-secondary hover:bg-[#f3f5f4]">
                        {{ 'header.profile'|trans }}
                    </a>
                    <a href="{{ path('logout') }}" class="flex items-center gap-2 rounded-sm px-3 py-2 text-body-lg text-text-secondary hover:bg-[#f3f5f4]">
                        <img src="{{ asset('images/login.svg') }}" width="24" height="24" alt="">
                        {{ 'header.logout'|trans }}
                    </a>
                {% else %}
                    <a href="{{ path('viisp_login_submit') }}" class="flex items-center gap-2 rounded-sm px-3 py-2 text-body-lg text-text-secondary hover:bg-[#f3f5f4]">
                        <img src="{{ asset('images/login.svg') }}" width="24" height="24" alt="">
                        {{ 'header.login'|trans }}
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</header>
