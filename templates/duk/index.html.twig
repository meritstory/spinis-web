{% extends 'base.html.twig' %}

{% block title %}{{ 'duk.title'|trans }}{% endblock %}

{% block body %}
    <main>
        <section class="pt-8 pb-16 bg-page">
            <div class="mx-auto max-w-[1200px] px-6">
                {% include '_breadcrumb.html.twig' with {crumbs: [{label: 'duk.breadcrumb.current'|trans}]} %}

                <h1 class="mt-8 mb-5 text-heading-h1 font-bold">{{ 'duk.heading'|trans }}</h1>
                <p class="max-w-[720px] text-body-lg text-text-secondary">{{ 'duk.description'|trans }}</p>
            </div>
        </section>

        <section class="py-20 bg-white">
            <div class="mx-auto max-w-[1200px] px-6">
                <div class="border-t border-border-default">
                    {% for faq in faqs %}
                        <details name="faq-accordion" {% if loop.first %}open{% endif %} class="group border-b border-border-default py-8">
                            <summary class="flex list-none items-center justify-between gap-4 text-[15px] font-semibold [&::-webkit-details-marker]:hidden">
                                {{ faq.question }}
                                <img src="{{ asset('images/chevron.svg') }}" class="h-6 w-6 shrink-0 transition-transform duration-150 group-open:rotate-180" alt="">
                            </summary>
                            <div class="mt-8 text-body-md text-gray-600">{{ faq.answer|sanitize_html }}</div>
                        </details>
                    {% endfor %}
                </div>
            </div>
        </section>

        <section class="py-16 bg-subtle">
            <div class="mx-auto max-w-[1200px] px-6 text-center">
                <h2 class="mb-3 text-heading-h1 text-text-primary font-bold">{{ 'duk.still_questions.heading'|trans }}</h2>
                <p class="mx-auto mb-8 max-w-[560px] text-body-lg text-text-secondary">{{ 'duk.still_questions.description'|trans }}</p>
                <a href="#" class="inline-block rounded-[8px] bg-primary px-12 py-4 text-body-lg text-white hover:bg-primary-dark">{{ 'duk.still_questions.cta'|trans }}</a>
            </div>
        </section>
    </main>
{% endblock %}
