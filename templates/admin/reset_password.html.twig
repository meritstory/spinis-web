{% extends '@EasyAdmin/page/login_minimal.html.twig' %}

{% block body_class 'page-login' %}
{% block page_title %}{{ page_title }}{% endblock %}

{% block wrapper_wrapper %}
    <div class="login-wrapper">
        <header class="main-header">
            <div id="header-logo">
                <div class="logo logo-long">{{ page_title }}</div>
            </div>
        </header>

        <section class="content">
            {% if error %}
                <div class="w-100 alert alert-danger rounded mb-3">
                    {{ error }}
                </div>
            {% endif %}

            {% if show_form %}
                <form method="post" action="{{ path('admin_reset_password', {token: token}) }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrf_token_intention) }}">

                    <div class="form-group">
                        <label class="form-control-label required" for="password">{{ 'login.reset.new_password'|trans }}</label>
                        <div class="form-widget">
                            <input type="password" id="password" name="password" class="form-control" required autocomplete="new-password">
                        </div>
                    </div>

                    <div class="form-group mt-3">
                        <label class="form-control-label required" for="password_confirm">{{ 'login.reset.new_password_confirm'|trans }}</label>
                        <div class="form-widget">
                            <input type="password" id="password_confirm" name="password_confirm" class="form-control" required autocomplete="new-password">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg btn-block w-100 mt-3">
                        {{ 'login.reset.submit'|trans }}
                    </button>
                </form>
            {% endif %}

            <div class="form-text mt-3">
                <a href="{{ path('admin_login') }}">{{ 'login.back_to_login'|trans }}</a>
            </div>
        </section>
    </div>
{% endblock %}
