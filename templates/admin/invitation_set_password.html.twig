{% extends '@EasyAdmin/page/login_minimal.html.twig' %}

{% block body_class 'page-login' %}
{% block page_title %}{{ page_title }}{% endblock %}

{% block wrapper_wrapper %}
    <div class="login-wrapper">
        <header class="main-header">
            <div id="header-logo">
                <div class="logo logo-long">{{ page_title }}</div>
            </div>
        </header>

        <section class="content">
            {% if error %}
                <div class="w-100 alert alert-danger rounded mb-3">
                    {{ error }}
                </div>
            {% endif %}

            {% if show_form %}
                <form method="post" action="{{ path('admin_invitation_link', {token: invitation_token}) }}" novalidate>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrf_token_intention) }}">

                    {% include 'admin/_password_fields.html.twig' with {
                        password_id: 'password',
                        password_confirm_id: 'password_confirm',
                        password_label: 'admin.invitation.new_password'|trans,
                        password_confirm_label: 'admin.invitation.new_password_confirm'|trans,
                        min_length: password_min_length,
                        show_requirements_hint: error is null,
                    } only %}

                    <button type="submit" class="btn btn-primary btn-lg btn-block w-100 mt-3">
                        {{ 'admin.invitation.submit'|trans }}
                    </button>
                </form>
            {% endif %}

            <div class="form-text mt-2">
                <a href="{{ path('admin_login') }}">{{ 'login.back_to_login'|trans }}</a>
            </div>
        </section>
    </div>
{% endblock %}
